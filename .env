# ================================================================
# 공통 기본값 — 변경이 없는 값은 여기서만 정의한다.
# 환경별로 달라지는 값은 .env.{APP_ENV} 에서만 설정한다.
# ================================================================

# Solr (SINK_TYPE=solr 일 때만 필요)
# SOLR_DIRECT_ENABLED=true → SOLR_URL 로 직접 접속
# SOLR_DIRECT_ENABLED=false → SOLR_RUNTIME_NAME 으로 t_crawl_runtime 조회
SOLR_DIRECT_ENABLED=false
SOLR_URL=
SOLR_RUNTIME_NAME=
SOLR_BATCH_SIZE=100
SOLR_COMMIT_WITHIN_MS=5000

# Sink
SINK_TYPE=file
FILE_SINK_DIR=./output

# Fetcher
DEFAULT_CRAWL_DELAY_MS=1000
HTTP_VERIFY_SSL=true

# Retry / Backoff
MAX_ATTEMPTS=5
BACKOFF_BASE_SECONDS=30
BACKOFF_MAX_SECONDS=3600
CLAIM_TIMEOUT_SECONDS=300

# Rules cache
RULES_CACHE_TTL_SECONDS=60

# Logging
LOG_DIR=./logs
LOG_LEVEL=INFO
LOG_ROTATION=daily
LOG_RETAIN_DAYS=30    # daily 모드: 며칠치 보관 (기본 30)
LOG_BACKUP_COUNT=10   # size 모드: 파일 몇 개 보관 (기본 10)
HEARTBEAT_INTERVAL_SECONDS=60
