{
    "_comment": "JSON 패턴: 전화번호 → 이메일. 기자명·특파원명은 Python 내장 패턴으로 처리 (use_yn=N).",
    "patterns": [
        {
            "label": "전화번호",
            "mask_str": "0[0-9]{1,2}[-.\\s/]?[0-9]{3,4}[-.\\s/]?[0-9]{4}",
            "replace_str": "***-****-****",
            "use_yn": "Y"
        },
        {
            "label": "이메일",
            "mask_str": "[a-zA-Z0-9._%+\\-]+@",
            "replace_str": "*****@",
            "use_yn": "Y"
        },
        {
            "label": "기자명",
            "mask_str": "([가-힣])([가-힣]+)([가-힣])\\s*기자",
            "replace_str": "\\1*\\3 기자",
            "use_yn": "N",
            "_note": "Python 내장 패턴으로 대체됨 — 2글자 이름 포함, callable 치환"
        },
        {
            "label": "특파원명",
            "mask_str": "([가-힣])([가-힣]+)([가-힣])(\\s+[가-힣]+)?\\s*특파원",
            "replace_str": "\\1*\\3\\4 특파원",
            "use_yn": "N",
            "_note": "Python 내장 패턴으로 대체됨 — 2글자 이름 포함, callable 치환"
        }
    ]
}
