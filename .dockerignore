# ----------------------------------------------------------------
# .dockerignore — docker build 컨텍스트에서 제외할 파일 목록.
#
# COPY . . 같은 명령이 있을 때 여기 적힌 파일은 이미지에 들어가지 않는다.
# 민감 정보, 불필요한 파일을 제외해 이미지 크기와 보안을 개선한다.
# ----------------------------------------------------------------

# 환경별 접속 정보 — 이미지에 넣지 않고 컨테이너 실행 시 --env-file 로 주입
.env.*

# 가상환경 — 이미지 안에서 pip install 로 다시 설치하므로 불필요
.venv/
venv/

# Python 바이트코드 캐시
__pycache__/
*.py[cod]

# 버전 관리
.git/
.gitignore

# 배포 스크립트 — 이미지 안에서 실행할 파일이 아님
deploy/

# 개발 도구
docs/
.claude/
.vscode/
.idea/

# 실행 중 생성되는 산출물
logs/
output/
*.log

# DB 관련 — 마이그레이션과 스키마 SQL 은 컨테이너 밖에서 별도 실행
db/
migrations/
alembic.ini
